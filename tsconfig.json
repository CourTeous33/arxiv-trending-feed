{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "@arxiv-feed/core/*": ["./packages/core/src/*"],
      "@arxiv-feed/functions/*": ["./packages/functions/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "frontend"]
}
